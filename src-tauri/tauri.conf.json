{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cosmos",
  "version": "0.1.1",
  "identifier": "com.bruno.cosmos",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Cosmos",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzOTYxMEQ4NkM1MDk3ODMKUldTRGwxQnMyQkNXRTlrYlJBcFdwbXM1RVVkS0FqYnAweDdTMkllN0lXTDdnaTVrTmh3bldUcXIK",
      "endpoints": [
        "https://github.com/esquyna360/cosmos-agents/releases/latest/download/latest.json"
      ]
    }
  }
}
